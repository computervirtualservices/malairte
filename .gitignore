# ── Compiled binaries (distributed via GitHub Releases, never in tree) ───────
# Anchored to repo root with leading '/' so we don't accidentally ignore
# cmd/malairte-node/ or cmd/malairte-cli/ source packages.
/malairte-node
/malairte-node.exe
/malairte-node-*
/malairte-cli
/malairte-cli.exe
/malairte-cli-*
/mlrt_gpu.dll
/mlrt_gpu.so
/mlrt_gpu.dylib

# ── Release artefacts (uploaded to GitHub Releases, drafted locally) ─────────
/SHA256SUMS
/SHA256SUMS.asc
/RELEASE_NOTES_v*.md

# ── Local Go build artefacts ─────────────────────────────────────────────────
bin/
dist/
build/
*.test
*.out

# ── CUDA / native compile outputs (only the .cu source belongs in tree) ──────
**/*.dll
**/*.so
**/*.dylib
**/*.obj
**/*.o
**/*.a
**/*.lib
**/*.exp
**/*.pdb

# ── Runtime data / chain state ───────────────────────────────────────────────
data/
chainstate/
blocks/
*.db
*.log

# ── Secrets & live keys — NEVER commit ───────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.seed
secrets/
private/
release-key/

# ── OS / editors ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Claude Code session metadata ─────────────────────────────────────────────
.claude/
